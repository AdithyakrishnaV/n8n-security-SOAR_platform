    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// AbuseIPDB \nconst abuseScore = item.data.abuseConfidenceScore;\nconst isTor = item.data.isTor;\nconst totalReports = item.data.totalReports;\nconst country = item.data.countryCode;\nconst isp = item.data.isp;\nconst ip = item.data.ipAddress;\nconst lastReported = item.data.lastReportedAt;\n\n// VirusTotal \nconst vtMalicious = item.data.attributes.last_analysis_stats.malicious;\nconst vtSuspicious = item.data.attributes.last_analysis_stats.suspicious;\n\n// risk score out of 100\nconst riskScore = Math.min(100, Math.round(\n  (vtMalicious * 1.5) +\n  (abuseScore * 0.4) +\n  (isTor ? 20 : 0) +\n  (totalReports > 50 ? 10 : 0)\n));\n\n// Severity label\nlet severity = \"LOW\";\nif (riskScore >= 80) severity = \"CRITICAL\";\nelse if (riskScore >= 60) severity = \"HIGH\";\nelse if (riskScore >= 40) severity = \"MEDIUM\";\n\nreturn [{\n  json: {\n    ip,\n    riskScore,\n    severity,\n    vtMalicious,\n    vtSuspicious,\n    abuseScore,\n    isTor,\n    totalReports,\n    country,\n    isp,\n    lastReported\n  }\n}];"
